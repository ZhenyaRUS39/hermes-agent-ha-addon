#!/usr/bin/with-contenv bash
# HA Addon: /data is ephemeral. We keep hermes-agent in /usr/local (persistent).
# venv lives alongside the source, both survive container restarts.

echo "[INFO] Setting up Hermes Agent..."

if [ ! -d /usr/local/hermes-agent/.git ]; then
    echo "[INFO] Cloning Hermes Agent..."
    git clone --branch "${HERMES_VERSION:-v2026.4.23}" --depth 1 \
        https://github.com/NousResearch/hermes-agent.git \
        /usr/local/hermes-agent
fi

cd /usr/local/hermes-agent

if [ ! -d venv ]; then
    echo "[INFO] Creating venv..."
    python3 -m venv venv
    ./venv/bin/pip install --upgrade pip
    ./venv/bin/pip install -e .
    echo "[INFO] Venv ready"
else
    echo "[INFO] Venv exists"
fi

echo "[INFO] Hermes Agent ready"
